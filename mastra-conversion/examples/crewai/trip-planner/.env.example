# Required: OpenAI API key for GPT-4o
OPENAI_API_KEY=sk-...

# Optional: Serper API key for better web search (https://serper.dev)
# Without this, falls back to DuckDuckGo Instant Answer API
SERPER_API_KEY=

# Optional: LibSQL URL for memory storage (default: file:./mastra.db)
# LIBSQL_URL=file:./mastra.db
